    "instagram",
    "tiktok",
    "facebook",
    "twitter",
    "pinterest",
    "optimized"
  ],
  "author": "Your Name",
  "license": "ISC",
  "dependencies": {
    "@mrnima/facebook-downloader": "^1.0.0",
    "@xaviabot/fb-downloader": "^1.0.14",
    "axios": "^1.6.0",
    "bitly": "^7.1.2",
    "btch-downloader": "^2.8.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "install": "^0.13.0",
    "node-fetch": "^2.7.0",
    "youtube-dl-exec": "^2.4.6",
    "ytdl-core": "^4.11.5"
  },
  "optionalDependencies": {
    "puppeteer-core": "^21.3.8",
    "yt-dlp-exec": "^1.0.2"
  },
  "devDependencies": {
